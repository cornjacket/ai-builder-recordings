{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016WvBojzaK9MvbdqhcKpJ35","type":"tool_result","content":"1\t// Package store provides a thread-safe in-memory store for User records.\n2\t//\n3\t// Purpose: Manages CRUD operations on User records using a sync.RWMutex-protected map.\n4\t// UUID v4 identifiers are generated via crypto/rand on each Create call.\n5\t// Tags: implementation, store\n6\tpackage store\n7\t\n8\timport (\n9\t\t\"crypto/rand\"\n10\t\t\"fmt\"\n11\t\t\"io\"\n12\t\t\"sync\"\n13\t)\n14\t\n15\t// User represents a user record.\n16\ttype User struct {\n17\t\tID    string\n18\t\tName  string\n19\t\tEmail string\n20\t}\n21\t\n22\t// Store is a thread-safe in-memory store for User records.\n23\ttype Store struct {\n24\t\tmu      sync.RWMutex\n25\t\trecords map[string]User\n26\t}\n27\t\n28\t// New returns an initialised Store ready for use.\n29\tfunc New() *Store {\n30\t\treturn &Store{records: make(map[string]User)}\n31\t}\n32\t\n33\t// Create inserts a new User with the given name and email, assigning a UUID v4 ID.\n34\tfunc (s *Store) Create(name, email string) User {\n35\t\ts.mu.Lock()\n36\t\tdefer s.mu.Unlock()\n37\t\tu := User{\n38\t\t\tID:    newUUID(),\n39\t\t\tName:  name,\n40\t\t\tEmail: email,\n41\t\t}\n42\t\ts.records[u.ID] = u\n43\t\treturn u\n44\t}\n45\t\n46\t// Get returns the User with the given ID and true, or a zero User and false if not found.\n47\tfunc (s *Store) Get(id string) (User, bool) {\n48\t\ts.mu.RLock()\n49\t\tdefer s.mu.RUnlock()\n50\t\tu, ok := s.records[id]\n51\t\treturn u, ok\n52\t}\n53\t\n54\t// Update replaces the name and email of the User with the given ID.\n55\t// Returns the updated User and true on success, or a zero User and false if the ID is unknown.\n56\tfunc (s *Store) Update(id, name, email string) (User, bool) {\n57\t\ts.mu.Lock()\n58\t\tdefer s.mu.Unlock()\n59\t\tif _, ok := s.records[id]; !ok {\n60\t\t\treturn User{}, false\n61\t\t}\n62\t\tu := User{ID: id, Name: name, Email: email}\n63\t\ts.records[id] = u\n64\t\treturn u, true\n65\t}\n66\t\n67\t// Delete removes the User with the given ID, returning true on success or false if not found.\n68\tfunc (s *Store) Delete(id string) bool {\n69\t\ts.mu.Lock()\n70\t\tdefer s.mu.Unlock()\n71\t\tif _, ok := s.records[id]; !ok {\n72\t\t\treturn false\n73\t\t}\n74\t\tdelete(s.records, id)\n75\t\treturn true\n76\t}\n77\t\n78\t// newUUID generates a random UUID v4.\n79\tfunc newUUID() string {\n80\t\tvar b [16]byte\n81\t\t_, _ = io.ReadFull(rand.Reader, b[:])\n82\t\tb[6] = (b[6] & 0x0f) | 0x40 // version 4\n83\t\tb[8] = (b[8] & 0x3f) | 0x80 // variant 10\n84\t\treturn fmt.Sprintf(\"%08x-%04x-%04x-%04x-%012x\",\n85\t\t\tb[0:4], b[4:6], b[6:8], b[8:10], b[10:16])\n86\t}\n87\t"}]},"parent_tool_use_id":null,"session_id":"b90751bb-dcbc-46ad-a36d-5bcf92f90ec0","uuid":"9d77a06a-bbff-47a6-b366-05dc8824b25f","timestamp":"2026-04-05T08:21:05.268Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/david/Go/src/github.com/cornjacket/ai-builder/acceptance-spec/sandbox/regressions/user-service/output/internal/userservice/store/store.go","content":"// Package store provides a thread-safe in-memory store for User records.\n//\n// Purpose: Manages CRUD operations on User records using a sync.RWMutex-protected map.\n// UUID v4 identifiers are generated via crypto/rand on each Create call.\n// Tags: implementation, store\npackage store\n\nimport (\n\t\"crypto/rand\"\n\t\"fmt\"\n\t\"io\"\n\t\"sync\"\n)\n\n// User represents a user record.\ntype User struct {\n\tID    string\n\tName  string\n\tEmail string\n}\n\n// Store is a thread-safe in-memory store for User records.\ntype Store struct {\n\tmu      sync.RWMutex\n\trecords map[string]User\n}\n\n// New returns an initialised Store ready for use.\nfunc New() *Store {\n\treturn &Store{records: make(map[string]User)}\n}\n\n// Create inserts a new User with the given name and email, assigning a UUID v4 ID.\nfunc (s *Store) Create(name, email string) User {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\tu := User{\n\t\tID:    newUUID(),\n\t\tName:  name,\n\t\tEmail: email,\n\t}\n\ts.records[u.ID] = u\n\treturn u\n}\n\n// Get returns the User with the given ID and true, or a zero User and false if not found.\nfunc (s *Store) Get(id string) (User, bool) {\n\ts.mu.RLock()\n\tdefer s.mu.RUnlock()\n\tu, ok := s.records[id]\n\treturn u, ok\n}\n\n// Update replaces the name and email of the User with the given ID.\n// Returns the updated User and true on success, or a zero User and false if the ID is unknown.\nfunc (s *Store) Update(id, name, email string) (User, bool) {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\tif _, ok := s.records[id]; !ok {\n\t\treturn User{}, false\n\t}\n\tu := User{ID: id, Name: name, Email: email}\n\ts.records[id] = u\n\treturn u, true\n}\n\n// Delete removes the User with the given ID, returning true on success or false if not found.\nfunc (s *Store) Delete(id string) bool {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\tif _, ok := s.records[id]; !ok {\n\t\treturn false\n\t}\n\tdelete(s.records, id)\n\treturn true\n}\n\n// newUUID generates a random UUID v4.\nfunc newUUID() string {\n\tvar b [16]byte\n\t_, _ = io.ReadFull(rand.Reader, b[:])\n\tb[6] = (b[6] & 0x0f) | 0x40 // version 4\n\tb[8] = (b[8] & 0x3f) | 0x80 // variant 10\n\treturn fmt.Sprintf(\"%08x-%04x-%04x-%04x-%012x\",\n\t\tb[0:4], b[4:6], b[6:8], b[8:10], b[10:16])\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
