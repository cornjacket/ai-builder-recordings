{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BRobEqPLYuzddWhACAwoVf","type":"tool_result","content":"1\t// Package lifecycle provides in-memory user CRUD and token-based authentication for the IAM listener.\n2\t//\n3\t// Purpose: Manages user registration, lookup, deletion, and session token lifecycle via five HTTP handlers.\n4\t// Exposes Handler() to register all routes on a *http.ServeMux.\n5\t// Tags: implementation, lifecycle\n6\tpackage lifecycle\n7\t\n8\timport (\n9\t\t\"encoding/json\"\n10\t\t\"net/http\"\n11\t\t\"strings\"\n12\t\t\"sync\"\n13\t\n14\t\t\"github.com/google/uuid\"\n15\t\t\"golang.org/x/crypto/bcrypt\"\n16\t)\n17\t\n18\t// User holds a single registered user's data.\n19\ttype User struct {\n20\t\tID           string\n21\t\tUsername     string\n22\t\tPasswordHash string\n23\t}\n24\t\n25\t// UserStore is a concurrent-safe dual-indexed map of users.\n26\ttype UserStore struct {\n27\t\tmu         sync.RWMutex\n28\t\tbyID       map[string]*User\n29\t\tbyUsername map[string]*User\n30\t}\n31\t\n32\t// TokenStore is a concurrent-safe map from token string to userID.\n33\ttype TokenStore struct {\n34\t\tmu     sync.RWMutex\n35\t\ttokens map[string]string\n36\t}\n37\t\n38\t// handler holds references to both stores and satisfies the routing methods.\n39\ttype handler struct {\n40\t\tusers  *UserStore\n41\t\ttokens *TokenStore\n42\t}\n43\t\n44\t// Handler constructs both stores and returns a *http.ServeMux with all five routes registered.\n45\tfunc Handler() *http.ServeMux {\n46\t\th := &handler{\n47\t\t\tusers: &UserStore{\n48\t\t\t\tbyID:       make(map[string]*User),\n49\t\t\t\tbyUsername: make(map[string]*User),\n50\t\t\t},\n51\t\t\ttokens: &TokenStore{\n52\t\t\t\ttokens: make(map[string]string),\n53\t\t\t},\n54\t\t}\n55\t\n56\t\tmux := http.NewServeMux()\n57\t\tmux.HandleFunc(\"/users\", h.usersRoot)\n58\t\tmux.HandleFunc(\"/users/\", h.usersID)\n59\t\tmux.HandleFunc(\"/auth/login\", h.login)\n60\t\tmux.HandleFunc(\"/auth/logout\", h.logout)\n61\t\treturn mux\n62\t}\n63\t\n64\t// writeJSON encodes v as JSON and writes it with the given status code.\n65\tfunc writeJSON(w http.ResponseWriter, status int, v any) {\n66\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n67\t\tw.WriteHeader(status)\n68\t\tjson.NewEncoder(w).Encode(v) //nolint:errcheck\n69\t}\n70\t\n71\t// writeError writes a {\"error\":\"<msg>\"} JSON response.\n72\tfunc writeError(w http.ResponseWriter, status int, msg string) {\n73\t\twriteJSON(w, status, map[string]string{\"error\": msg})\n74\t}\n75\t\n76\t// usersRoot handles POST /users.\n77\tfunc (h *handler) usersRoot(w http.ResponseWriter, r *http.Request) {\n78\t\tif r.Method != http.MethodPost {\n79\t\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n80\t\t\treturn\n81\t\t}\n82\t\n83\t\tvar req struct {\n84\t\t\tUsername string `json:\"username\"`\n85\t\t\tPassword string `json:\"password\"`\n86\t\t}\n87\t\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n88\t\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n89\t\t\treturn\n90\t\t}\n91\t\tif req.Username == \"\" || req.Password == \"\" {\n92\t\t\twriteError(w, http.StatusBadRequest, \"username and password are required\")\n93\t\t\treturn\n94\t\t}\n95\t\n96\t\thash, err := bcrypt.GenerateFromPassword([]byte(req.Password), 12)\n97\t\tif err != nil {\n98\t\t\twriteError(w, http.StatusBadRequest, \"failed to hash password\")\n99\t\t\treturn\n100\t\t}\n101\t\n102\t\th.users.mu.Lock()\n103\t\tdefer h.users.mu.Unlock()\n104\t\n105\t\tif _, exists := h.users.byUsername[req.Username]; exists {\n106\t\t\twriteError(w, http.StatusBadRequest, \"username already taken\")\n107\t\t\treturn\n108\t\t}\n109\t\n110\t\tu := &User{\n111\t\t\tID:           uuid.NewString(),\n112\t\t\tUsername:     req.Username,\n113\t\t\tPasswordHash: string(hash),\n114\t\t}\n115\t\th.users.byID[u.ID] = u\n116\t\th.users.byUsername[u.Username] = u\n117\t\n118\t\twriteJSON(w, http.StatusCreated, map[string]string{\n119\t\t\t\"id\":       u.ID,\n120\t\t\t\"username\": u.Username,\n121\t\t})\n122\t}\n123\t\n124\t// usersID handles GET /users/{id} and DELETE /users/{id}.\n125\tfunc (h *handler) usersID(w http.ResponseWriter, r *http.Request) {\n126\t\tid := strings.TrimPrefix(r.URL.Path, \"/users/\")\n127\t\tif id == \"\" {\n128\t\t\twriteError(w, http.StatusBadRequest, \"missing user id\")\n129\t\t\treturn\n130\t\t}\n131\t\n132\t\tswitch r.Method {\n133\t\tcase http.MethodGet:\n134\t\t\th.users.mu.RLock()\n135\t\t\tu, ok := h.users.byID[id]\n136\t\t\th.users.mu.RUnlock()\n137\t\n138\t\t\tif !ok {\n139\t\t\t\twriteError(w, http.StatusNotFound, \"user not found\")\n140\t\t\t\treturn\n141\t\t\t}\n142\t\t\twriteJSON(w, http.StatusOK, map[string]string{\n143\t\t\t\t\"id\":       u.ID,\n144\t\t\t\t\"username\": u.Username,\n145\t\t\t})\n146\t\n147\t\tcase http.MethodDelete:\n148\t\t\th.users.mu.Lock()\n149\t\t\tu, ok := h.users.byID[id]\n150\t\t\tif !ok {\n151\t\t\t\th.users.mu.Unlock()\n152\t\t\t\twriteError(w, http.StatusNotFound, \"user not found\")\n153\t\t\t\treturn\n154\t\t\t}\n155\t\t\tdelete(h.users.byID, u.ID)\n156\t\t\tdelete(h.users.byUsername, u.Username)\n157\t\t\th.users.mu.Unlock()\n158\t\n159\t\t\t// Cascade: invalidate any tokens belonging to this user.\n160\t\t\th.tokens.mu.Lock()\n161\t\t\tfor tok, uid := range h.tokens.tokens {\n162\t\t\t\tif uid == id {\n163\t\t\t\t\tdelete(h.tokens.tokens, tok)\n164\t\t\t\t}\n165\t\t\t}\n166\t\t\th.tokens.mu.Unlock()\n167\t\n168\t\t\tw.WriteHeader(http.StatusOK)\n169\t\n170\t\tdefault:\n171\t\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n172\t\t}\n173\t}\n174\t\n175\t// login handles POST /auth/login.\n176\tfunc (h *handler) login(w http.ResponseWriter, r *http.Request) {\n177\t\tif r.Method != http.MethodPost {\n178\t\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n179\t\t\treturn\n180\t\t}\n181\t\n182\t\tvar req struct {\n183\t\t\tUsername string `json:\"username\"`\n184\t\t\tPassword string `json:\"password\"`\n185\t\t}\n186\t\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n187\t\t\twriteError(w, http.StatusUnauthorized, \"invalid request body\")\n188\t\t\treturn\n189\t\t}\n190\t\n191\t\th.users.mu.RLock()\n192\t\tu, ok := h.users.byUsername[req.Username]\n193\t\th.users.mu.RUnlock()\n194\t\n195\t\tif !ok {\n196\t\t\twriteError(w, http.StatusUnauthorized, \"invalid credentials\")\n197\t\t\treturn\n198\t\t}\n199\t\n200\t\tif err := bcrypt.CompareHashAndPassword([]byte(u.PasswordHash), []byte(req.Password)); err != nil {\n201\t\t\twriteError(w, http.StatusUnauthorized, \"invalid credentials\")\n202\t\t\treturn\n203\t\t}\n204\t\n205\t\ttoken := uuid.NewString()\n206\t\n207\t\th.tokens.mu.Lock()\n208\t\th.tokens.tokens[token] = u.ID\n209\t\th.tokens.mu.Unlock()\n210\t\n211\t\twriteJSON(w, http.StatusOK, map[string]string{\"token\": token})\n212\t}\n213\t\n214\t// logout handles POST /auth/logout.\n215\tfunc (h *handler) logout(w http.ResponseWriter, r *http.Request) {\n216\t\tif r.Method != http.MethodPost {\n217\t\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n218\t\t\treturn\n219\t\t}\n220\t\n221\t\tauthHeader := r.Header.Get(\"Authorization\")\n222\t\tif !strings.HasPrefix(authHeader, \"Bearer \") {\n223\t\t\twriteError(w, http.StatusUnauthorized, \"missing or invalid Authorization header\")\n224\t\t\treturn\n225\t\t}\n226\t\ttoken := strings.TrimPrefix(authHeader, \"Bearer \")\n227\t\n228\t\th.tokens.mu.Lock()\n229\t\tdefer h.tokens.mu.Unlock()\n230\t\n231\t\tif _, ok := h.tokens.tokens[token]; !ok {\n232\t\t\twriteError(w, http.StatusUnauthorized, \"token not found\")\n233\t\t\treturn\n234\t\t}\n235\t\tdelete(h.tokens.tokens, token)\n236\t\n237\t\tw.WriteHeader(http.StatusOK)\n238\t}\n239\t"}]},"parent_tool_use_id":null,"session_id":"aca4c537-a36b-4427-8a8d-a1f25059b631","uuid":"4d2611d6-cae4-44ff-a00c-427b16dec094","timestamp":"2026-04-05T09:24:38.866Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/david/Go/src/github.com/cornjacket/ai-builder/acceptance-spec/sandbox/regressions/platform-monolith/output/internal/iam/internal/iam/lifecycle/lifecycle.go","content":"// Package lifecycle provides in-memory user CRUD and token-based authentication for the IAM listener.\n//\n// Purpose: Manages user registration, lookup, deletion, and session token lifecycle via five HTTP handlers.\n// Exposes Handler() to register all routes on a *http.ServeMux.\n// Tags: implementation, lifecycle\npackage lifecycle\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"strings\"\n\t\"sync\"\n\n\t\"github.com/google/uuid\"\n\t\"golang.org/x/crypto/bcrypt\"\n)\n\n// User holds a single registered user's data.\ntype User struct {\n\tID           string\n\tUsername     string\n\tPasswordHash string\n}\n\n// UserStore is a concurrent-safe dual-indexed map of users.\ntype UserStore struct {\n\tmu         sync.RWMutex\n\tbyID       map[string]*User\n\tbyUsername map[string]*User\n}\n\n// TokenStore is a concurrent-safe map from token string to userID.\ntype TokenStore struct {\n\tmu     sync.RWMutex\n\ttokens map[string]string\n}\n\n// handler holds references to both stores and satisfies the routing methods.\ntype handler struct {\n\tusers  *UserStore\n\ttokens *TokenStore\n}\n\n// Handler constructs both stores and returns a *http.ServeMux with all five routes registered.\nfunc Handler() *http.ServeMux {\n\th := &handler{\n\t\tusers: &UserStore{\n\t\t\tbyID:       make(map[string]*User),\n\t\t\tbyUsername: make(map[string]*User),\n\t\t},\n\t\ttokens: &TokenStore{\n\t\t\ttokens: make(map[string]string),\n\t\t},\n\t}\n\n\tmux := http.NewServeMux()\n\tmux.HandleFunc(\"/users\", h.usersRoot)\n\tmux.HandleFunc(\"/users/\", h.usersID)\n\tmux.HandleFunc(\"/auth/login\", h.login)\n\tmux.HandleFunc(\"/auth/logout\", h.logout)\n\treturn mux\n}\n\n// writeJSON encodes v as JSON and writes it with the given status code.\nfunc writeJSON(w http.ResponseWriter, status int, v any) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(status)\n\tjson.NewEncoder(w).Encode(v) //nolint:errcheck\n}\n\n// writeError writes a {\"error\":\"<msg>\"} JSON response.\nfunc writeError(w http.ResponseWriter, status int, msg string) {\n\twriteJSON(w, status, map[string]string{\"error\": msg})\n}\n\n// usersRoot handles POST /users.\nfunc (h *handler) usersRoot(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n\t\treturn\n\t}\n\n\tvar req struct {\n\t\tUsername string `json:\"username\"`\n\t\tPassword string `json:\"password\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n\t\treturn\n\t}\n\tif req.Username == \"\" || req.Password == \"\" {\n\t\twriteError(w, http.StatusBadRequest, \"username and password are required\")\n\t\treturn\n\t}\n\n\thash, err := bcrypt.GenerateFromPassword([]byte(req.Password), 12)\n\tif err != nil {\n\t\twriteError(w, http.StatusBadRequest, \"failed to hash password\")\n\t\treturn\n\t}\n\n\th.users.mu.Lock()\n\tdefer h.users.mu.Unlock()\n\n\tif _, exists := h.users.byUsername[req.Username]; exists {\n\t\twriteError(w, http.StatusBadRequest, \"username already taken\")\n\t\treturn\n\t}\n\n\tu := &User{\n\t\tID:           uuid.NewString(),\n\t\tUsername:     req.Username,\n\t\tPasswordHash: string(hash),\n\t}\n\th.users.byID[u.ID] = u\n\th.users.byUsername[u.Username] = u\n\n\twriteJSON(w, http.StatusCreated, map[string]string{\n\t\t\"id\":       u.ID,\n\t\t\"username\": u.Username,\n\t})\n}\n\n// usersID handles GET /users/{id} and DELETE /users/{id}.\nfunc (h *handler) usersID(w http.ResponseWriter, r *http.Request) {\n\tid := strings.TrimPrefix(r.URL.Path, \"/users/\")\n\tif id == \"\" {\n\t\twriteError(w, http.StatusBadRequest, \"missing user id\")\n\t\treturn\n\t}\n\n\tswitch r.Method {\n\tcase http.MethodGet:\n\t\th.users.mu.RLock()\n\t\tu, ok := h.users.byID[id]\n\t\th.users.mu.RUnlock()\n\n\t\tif !ok {\n\t\t\twriteError(w, http.StatusNotFound, \"user not found\")\n\t\t\treturn\n\t\t}\n\t\twriteJSON(w, http.StatusOK, map[string]string{\n\t\t\t\"id\":       u.ID,\n\t\t\t\"username\": u.Username,\n\t\t})\n\n\tcase http.MethodDelete:\n\t\th.users.mu.Lock()\n\t\tu, ok := h.users.byID[id]\n\t\tif !ok {\n\t\t\th.users.mu.Unlock()\n\t\t\twriteError(w, http.StatusNotFound, \"user not found\")\n\t\t\treturn\n\t\t}\n\t\tdelete(h.users.byID, u.ID)\n\t\tdelete(h.users.byUsername, u.Username)\n\t\th.users.mu.Unlock()\n\n\t\t// Cascade: invalidate any tokens belonging to this user.\n\t\th.tokens.mu.Lock()\n\t\tfor tok, uid := range h.tokens.tokens {\n\t\t\tif uid == id {\n\t\t\t\tdelete(h.tokens.tokens, tok)\n\t\t\t}\n\t\t}\n\t\th.tokens.mu.Unlock()\n\n\t\tw.WriteHeader(http.StatusOK)\n\n\tdefault:\n\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n\t}\n}\n\n// login handles POST /auth/login.\nfunc (h *handler) login(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n\t\treturn\n\t}\n\n\tvar req struct {\n\t\tUsername string `json:\"username\"`\n\t\tPassword string `json:\"password\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\twriteError(w, http.StatusUnauthorized, \"invalid request body\")\n\t\treturn\n\t}\n\n\th.users.mu.RLock()\n\tu, ok := h.users.byUsername[req.Username]\n\th.users.mu.RUnlock()\n\n\tif !ok {\n\t\twriteError(w, http.StatusUnauthorized, \"invalid credentials\")\n\t\treturn\n\t}\n\n\tif err := bcrypt.CompareHashAndPassword([]byte(u.PasswordHash), []byte(req.Password)); err != nil {\n\t\twriteError(w, http.StatusUnauthorized, \"invalid credentials\")\n\t\treturn\n\t}\n\n\ttoken := uuid.NewString()\n\n\th.tokens.mu.Lock()\n\th.tokens.tokens[token] = u.ID\n\th.tokens.mu.Unlock()\n\n\twriteJSON(w, http.StatusOK, map[string]string{\"token\": token})\n}\n\n// logout handles POST /auth/logout.\nfunc (h *handler) logout(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\tw.WriteHeader(http.StatusMethodNotAllowed)\n\t\treturn\n\t}\n\n\tauthHeader := r.Header.Get(\"Authorization\")\n\tif !strings.HasPrefix(authHeader, \"Bearer \") {\n\t\twriteError(w, http.StatusUnauthorized, \"missing or invalid Authorization header\")\n\t\treturn\n\t}\n\ttoken := strings.TrimPrefix(authHeader, \"Bearer \")\n\n\th.tokens.mu.Lock()\n\tdefer h.tokens.mu.Unlock()\n\n\tif _, ok := h.tokens.tokens[token]; !ok {\n\t\twriteError(w, http.StatusUnauthorized, \"token not found\")\n\t\treturn\n\t}\n\tdelete(h.tokens.tokens, token)\n\n\tw.WriteHeader(http.StatusOK)\n}\n","numLines":239,"startLine":1,"totalLines":239}}}
