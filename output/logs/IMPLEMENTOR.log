{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YHpaAk8dcikeybsqt8M2Pr","type":"tool_result","content":"1\t// Package authz provides in-memory RBAC role management and permission-check handling.\n2\t//\n3\t// Purpose: Manages roles and user-role assignments with a permission-check endpoint.\n4\t// Exposes a *http.ServeMux for registration by the IAM listener.\n5\t// Tags: implementation, authz\n6\tpackage authz\n7\t\n8\timport (\n9\t\t\"encoding/json\"\n10\t\t\"net/http\"\n11\t\t\"strings\"\n12\t\t\"sync\"\n13\t\n14\t\t\"github.com/google/uuid\"\n15\t)\n16\t\n17\t// Role represents an access-control role with a set of named permissions.\n18\ttype Role struct {\n19\t\tID          string   `json:\"id\"`\n20\t\tName        string   `json:\"name\"`\n21\t\tPermissions []string `json:\"permissions\"`\n22\t}\n23\t\n24\ttype handler struct {\n25\t\tmu        sync.RWMutex\n26\t\troleStore map[string]Role     // keyed by role ID\n27\t\tuserRoles map[string][]string // keyed by user ID → []roleID\n28\t}\n29\t\n30\t// Handler returns a *http.ServeMux with the five authz endpoints registered.\n31\tfunc Handler() *http.ServeMux {\n32\t\th := &handler{\n33\t\t\troleStore: make(map[string]Role),\n34\t\t\tuserRoles: make(map[string][]string),\n35\t\t}\n36\t\tmux := http.NewServeMux()\n37\t\tmux.HandleFunc(\"/roles\", h.handleRoles)\n38\t\tmux.HandleFunc(\"/users/\", h.handleUsers)\n39\t\tmux.HandleFunc(\"/authz/check\", h.handleAuthzCheck)\n40\t\treturn mux\n41\t}\n42\t\n43\tfunc writeJSON(w http.ResponseWriter, status int, v any) {\n44\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n45\t\tw.WriteHeader(status)\n46\t\tjson.NewEncoder(w).Encode(v)\n47\t}\n48\t\n49\tfunc writeError(w http.ResponseWriter, status int, msg string) {\n50\t\twriteJSON(w, status, map[string]string{\"error\": msg})\n51\t}\n52\t\n53\t// handleRoles dispatches POST /roles and GET /roles.\n54\tfunc (h *handler) handleRoles(w http.ResponseWriter, r *http.Request) {\n55\t\tswitch r.Method {\n56\t\tcase http.MethodPost:\n57\t\t\th.createRole(w, r)\n58\t\tcase http.MethodGet:\n59\t\t\th.listRoles(w, r)\n60\t\tdefault:\n61\t\t\twriteError(w, http.StatusMethodNotAllowed, \"method not allowed\")\n62\t\t}\n63\t}\n64\t\n65\tfunc (h *handler) createRole(w http.ResponseWriter, r *http.Request) {\n66\t\tvar body struct {\n67\t\t\tName        string   `json:\"name\"`\n68\t\t\tPermissions []string `json:\"permissions\"`\n69\t\t}\n70\t\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil {\n71\t\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n72\t\t\treturn\n73\t\t}\n74\t\tif body.Name == \"\" {\n75\t\t\twriteError(w, http.StatusBadRequest, \"name is required\")\n76\t\t\treturn\n77\t\t}\n78\t\tperms := body.Permissions\n79\t\tif perms == nil {\n80\t\t\tperms = []string{}\n81\t\t}\n82\t\trole := Role{\n83\t\t\tID:          uuid.New().String(),\n84\t\t\tName:        body.Name,\n85\t\t\tPermissions: perms,\n86\t\t}\n87\t\th.mu.Lock()\n88\t\th.roleStore[role.ID] = role\n89\t\th.mu.Unlock()\n90\t\twriteJSON(w, http.StatusCreated, role)\n91\t}\n92\t\n93\tfunc (h *handler) listRoles(w http.ResponseWriter, r *http.Request) {\n94\t\th.mu.RLock()\n95\t\troles := make([]Role, 0, len(h.roleStore))\n96\t\tfor _, role := range h.roleStore {\n97\t\t\troles = append(roles, role)\n98\t\t}\n99\t\th.mu.RUnlock()\n100\t\twriteJSON(w, http.StatusOK, roles)\n101\t}\n102\t\n103\t// handleUsers dispatches POST /users/{id}/roles and GET /users/{id}/roles.\n104\tfunc (h *handler) handleUsers(w http.ResponseWriter, r *http.Request) {\n105\t\t// Path: /users/{id}/roles\n106\t\tparts := strings.Split(strings.Trim(r.URL.Path, \"/\"), \"/\")\n107\t\tif len(parts) != 3 || parts[0] != \"users\" || parts[2] != \"roles\" {\n108\t\t\twriteError(w, http.StatusNotFound, \"not found\")\n109\t\t\treturn\n110\t\t}\n111\t\tuserID := parts[1]\n112\t\tif userID == \"\" {\n113\t\t\twriteError(w, http.StatusBadRequest, \"user id required\")\n114\t\t\treturn\n115\t\t}\n116\t\tswitch r.Method {\n117\t\tcase http.MethodPost:\n118\t\t\th.assignRole(w, r, userID)\n119\t\tcase http.MethodGet:\n120\t\t\th.getUserRoles(w, r, userID)\n121\t\tdefault:\n122\t\t\twriteError(w, http.StatusMethodNotAllowed, \"method not allowed\")\n123\t\t}\n124\t}\n125\t\n126\tfunc (h *handler) assignRole(w http.ResponseWriter, r *http.Request, userID string) {\n127\t\tvar body struct {\n128\t\t\tRoleID string `json:\"roleId\"`\n129\t\t}\n130\t\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil {\n131\t\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n132\t\t\treturn\n133\t\t}\n134\t\tif body.RoleID == \"\" {\n135\t\t\twriteError(w, http.StatusBadRequest, \"roleId is required\")\n136\t\t\treturn\n137\t\t}\n138\t\th.mu.Lock()\n139\t\tdefer h.mu.Unlock()\n140\t\tif _, ok := h.roleStore[body.RoleID]; !ok {\n141\t\t\twriteError(w, http.StatusNotFound, \"role not found\")\n142\t\t\treturn\n143\t\t}\n144\t\tfor _, id := range h.userRoles[userID] {\n145\t\t\tif id == body.RoleID {\n146\t\t\t\tw.WriteHeader(http.StatusCreated)\n147\t\t\t\treturn\n148\t\t\t}\n149\t\t}\n150\t\th.userRoles[userID] = append(h.userRoles[userID], body.RoleID)\n151\t\tw.WriteHeader(http.StatusCreated)\n152\t}\n153\t\n154\tfunc (h *handler) getUserRoles(w http.ResponseWriter, r *http.Request, userID string) {\n155\t\th.mu.RLock()\n156\t\troleIDs := h.userRoles[userID]\n157\t\troles := make([]Role, 0, len(roleIDs))\n158\t\tfor _, id := range roleIDs {\n159\t\t\tif role, ok := h.roleStore[id]; ok {\n160\t\t\t\troles = append(roles, role)\n161\t\t\t}\n162\t\t}\n163\t\th.mu.RUnlock()\n164\t\twriteJSON(w, http.StatusOK, roles)\n165\t}\n166\t\n167\t// handleAuthzCheck handles POST /authz/check.\n168\tfunc (h *handler) handleAuthzCheck(w http.ResponseWriter, r *http.Request) {\n169\t\tif r.Method != http.MethodPost {\n170\t\t\twriteError(w, http.StatusMethodNotAllowed, \"method not allowed\")\n171\t\t\treturn\n172\t\t}\n173\t\tvar body struct {\n174\t\t\tUserID     string `json:\"userId\"`\n175\t\t\tPermission string `json:\"permission\"`\n176\t\t}\n177\t\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil {\n178\t\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n179\t\t\treturn\n180\t\t}\n181\t\th.mu.RLock()\n182\t\troleIDs := h.userRoles[body.UserID]\n183\t\tallowed := false\n184\touter:\n185\t\tfor _, id := range roleIDs {\n186\t\t\trole, ok := h.roleStore[id]\n187\t\t\tif !ok {\n188\t\t\t\tcontinue\n189\t\t\t}\n190\t\t\tfor _, p := range role.Permissions {\n191\t\t\t\tif p == body.Permission {\n192\t\t\t\t\tallowed = true\n193\t\t\t\t\tbreak outer\n194\t\t\t\t}\n195\t\t\t}\n196\t\t}\n197\t\th.mu.RUnlock()\n198\t\twriteJSON(w, http.StatusOK, map[string]bool{\"allowed\": allowed})\n199\t}\n200\t"}]},"parent_tool_use_id":null,"session_id":"aca4c537-a36b-4427-8a8d-a1f25059b631","uuid":"9f7ceb75-5a2f-4345-ad81-1d7e8eacfc48","timestamp":"2026-04-05T09:24:39.488Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/david/Go/src/github.com/cornjacket/ai-builder/acceptance-spec/sandbox/regressions/platform-monolith/output/internal/iam/internal/iam/authz/authz.go","content":"// Package authz provides in-memory RBAC role management and permission-check handling.\n//\n// Purpose: Manages roles and user-role assignments with a permission-check endpoint.\n// Exposes a *http.ServeMux for registration by the IAM listener.\n// Tags: implementation, authz\npackage authz\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"strings\"\n\t\"sync\"\n\n\t\"github.com/google/uuid\"\n)\n\n// Role represents an access-control role with a set of named permissions.\ntype Role struct {\n\tID          string   `json:\"id\"`\n\tName        string   `json:\"name\"`\n\tPermissions []string `json:\"permissions\"`\n}\n\ntype handler struct {\n\tmu        sync.RWMutex\n\troleStore map[string]Role     // keyed by role ID\n\tuserRoles map[string][]string // keyed by user ID → []roleID\n}\n\n// Handler returns a *http.ServeMux with the five authz endpoints registered.\nfunc Handler() *http.ServeMux {\n\th := &handler{\n\t\troleStore: make(map[string]Role),\n\t\tuserRoles: make(map[string][]string),\n\t}\n\tmux := http.NewServeMux()\n\tmux.HandleFunc(\"/roles\", h.handleRoles)\n\tmux.HandleFunc(\"/users/\", h.handleUsers)\n\tmux.HandleFunc(\"/authz/check\", h.handleAuthzCheck)\n\treturn mux\n}\n\nfunc writeJSON(w http.ResponseWriter, status int, v any) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(status)\n\tjson.NewEncoder(w).Encode(v)\n}\n\nfunc writeError(w http.ResponseWriter, status int, msg string) {\n\twriteJSON(w, status, map[string]string{\"error\": msg})\n}\n\n// handleRoles dispatches POST /roles and GET /roles.\nfunc (h *handler) handleRoles(w http.ResponseWriter, r *http.Request) {\n\tswitch r.Method {\n\tcase http.MethodPost:\n\t\th.createRole(w, r)\n\tcase http.MethodGet:\n\t\th.listRoles(w, r)\n\tdefault:\n\t\twriteError(w, http.StatusMethodNotAllowed, \"method not allowed\")\n\t}\n}\n\nfunc (h *handler) createRole(w http.ResponseWriter, r *http.Request) {\n\tvar body struct {\n\t\tName        string   `json:\"name\"`\n\t\tPermissions []string `json:\"permissions\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil {\n\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n\t\treturn\n\t}\n\tif body.Name == \"\" {\n\t\twriteError(w, http.StatusBadRequest, \"name is required\")\n\t\treturn\n\t}\n\tperms := body.Permissions\n\tif perms == nil {\n\t\tperms = []string{}\n\t}\n\trole := Role{\n\t\tID:          uuid.New().String(),\n\t\tName:        body.Name,\n\t\tPermissions: perms,\n\t}\n\th.mu.Lock()\n\th.roleStore[role.ID] = role\n\th.mu.Unlock()\n\twriteJSON(w, http.StatusCreated, role)\n}\n\nfunc (h *handler) listRoles(w http.ResponseWriter, r *http.Request) {\n\th.mu.RLock()\n\troles := make([]Role, 0, len(h.roleStore))\n\tfor _, role := range h.roleStore {\n\t\troles = append(roles, role)\n\t}\n\th.mu.RUnlock()\n\twriteJSON(w, http.StatusOK, roles)\n}\n\n// handleUsers dispatches POST /users/{id}/roles and GET /users/{id}/roles.\nfunc (h *handler) handleUsers(w http.ResponseWriter, r *http.Request) {\n\t// Path: /users/{id}/roles\n\tparts := strings.Split(strings.Trim(r.URL.Path, \"/\"), \"/\")\n\tif len(parts) != 3 || parts[0] != \"users\" || parts[2] != \"roles\" {\n\t\twriteError(w, http.StatusNotFound, \"not found\")\n\t\treturn\n\t}\n\tuserID := parts[1]\n\tif userID == \"\" {\n\t\twriteError(w, http.StatusBadRequest, \"user id required\")\n\t\treturn\n\t}\n\tswitch r.Method {\n\tcase http.MethodPost:\n\t\th.assignRole(w, r, userID)\n\tcase http.MethodGet:\n\t\th.getUserRoles(w, r, userID)\n\tdefault:\n\t\twriteError(w, http.StatusMethodNotAllowed, \"method not allowed\")\n\t}\n}\n\nfunc (h *handler) assignRole(w http.ResponseWriter, r *http.Request, userID string) {\n\tvar body struct {\n\t\tRoleID string `json:\"roleId\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil {\n\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n\t\treturn\n\t}\n\tif body.RoleID == \"\" {\n\t\twriteError(w, http.StatusBadRequest, \"roleId is required\")\n\t\treturn\n\t}\n\th.mu.Lock()\n\tdefer h.mu.Unlock()\n\tif _, ok := h.roleStore[body.RoleID]; !ok {\n\t\twriteError(w, http.StatusNotFound, \"role not found\")\n\t\treturn\n\t}\n\tfor _, id := range h.userRoles[userID] {\n\t\tif id == body.RoleID {\n\t\t\tw.WriteHeader(http.StatusCreated)\n\t\t\treturn\n\t\t}\n\t}\n\th.userRoles[userID] = append(h.userRoles[userID], body.RoleID)\n\tw.WriteHeader(http.StatusCreated)\n}\n\nfunc (h *handler) getUserRoles(w http.ResponseWriter, r *http.Request, userID string) {\n\th.mu.RLock()\n\troleIDs := h.userRoles[userID]\n\troles := make([]Role, 0, len(roleIDs))\n\tfor _, id := range roleIDs {\n\t\tif role, ok := h.roleStore[id]; ok {\n\t\t\troles = append(roles, role)\n\t\t}\n\t}\n\th.mu.RUnlock()\n\twriteJSON(w, http.StatusOK, roles)\n}\n\n// handleAuthzCheck handles POST /authz/check.\nfunc (h *handler) handleAuthzCheck(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\twriteError(w, http.StatusMethodNotAllowed, \"method not allowed\")\n\t\treturn\n\t}\n\tvar body struct {\n\t\tUserID     string `json:\"userId\"`\n\t\tPermission string `json:\"permission\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil {\n\t\twriteError(w, http.StatusBadRequest, \"invalid request body\")\n\t\treturn\n\t}\n\th.mu.RLock()\n\troleIDs := h.userRoles[body.UserID]\n\tallowed := false\nouter:\n\tfor _, id := range roleIDs {\n\t\trole, ok := h.roleStore[id]\n\t\tif !ok {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, p := range role.Permissions {\n\t\t\tif p == body.Permission {\n\t\t\t\tallowed = true\n\t\t\t\tbreak outer\n\t\t\t}\n\t\t}\n\t}\n\th.mu.RUnlock()\n\twriteJSON(w, http.StatusOK, map[string]bool{\"allowed\": allowed})\n}\n","numLines":200,"startLine":1,"totalLines":200}}}
