{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XndeuDQrVkM2KXXHBirvCr","type":"tool_result","content":"1\t// Package store provides a thread-safe in-memory store for User records.\n2\t//\n3\t// Purpose: CRUD operations on User records backed by a map guarded by sync.RWMutex,\n4\t// with UUID generation for new record IDs.\n5\t//\n6\t// Tags: implementation, store\n7\tpackage store\n8\t\n9\timport (\n10\t\t\"sync\"\n11\t\n12\t\t\"github.com/google/uuid\"\n13\t)\n14\t\n15\t// User represents a user record.\n16\ttype User struct {\n17\t\tID    string\n18\t\tName  string\n19\t\tEmail string\n20\t}\n21\t\n22\t// Store is a thread-safe in-memory store for User records.\n23\ttype Store struct {\n24\t\tmu   sync.RWMutex\n25\t\tdata map[string]User\n26\t}\n27\t\n28\t// New returns an initialised *Store ready for use.\n29\tfunc New() *Store {\n30\t\treturn &Store{data: make(map[string]User)}\n31\t}\n32\t\n33\t// Create ignores user.ID, assigns a fresh UUID, stores the record, and returns\n34\t// the populated User.\n35\tfunc (s *Store) Create(user User) User {\n36\t\ts.mu.Lock()\n37\t\tdefer s.mu.Unlock()\n38\t\n39\t\tuser.ID = uuid.NewString()\n40\t\ts.data[user.ID] = user\n41\t\treturn user\n42\t}\n43\t\n44\t// Get returns the User for id and true, or an empty User and false if not found.\n45\tfunc (s *Store) Get(id string) (User, bool) {\n46\t\ts.mu.RLock()\n47\t\tdefer s.mu.RUnlock()\n48\t\n49\t\tu, ok := s.data[id]\n50\t\treturn u, ok\n51\t}\n52\t\n53\t// Update replaces the stored record for id with user (preserving the original\n54\t// ID) and returns the updated User and true. Returns (User{}, false) if id is\n55\t// not found.\n56\tfunc (s *Store) Update(id string, user User) (User, bool) {\n57\t\ts.mu.Lock()\n58\t\tdefer s.mu.Unlock()\n59\t\n60\t\tif _, ok := s.data[id]; !ok {\n61\t\t\treturn User{}, false\n62\t\t}\n63\t\tuser.ID = id\n64\t\ts.data[id] = user\n65\t\treturn user, true\n66\t}\n67\t\n68\t// Delete removes the record for id and returns true, or false if not found.\n69\tfunc (s *Store) Delete(id string) bool {\n70\t\ts.mu.Lock()\n71\t\tdefer s.mu.Unlock()\n72\t\n73\t\tif _, ok := s.data[id]; !ok {\n74\t\t\treturn false\n75\t\t}\n76\t\tdelete(s.data, id)\n77\t\treturn true\n78\t}\n79\t"}]},"parent_tool_use_id":null,"session_id":"d69bcd9d-aeb5-422d-9b91-4592528013f2","uuid":"aee0dc9c-4057-47c5-b706-894664aefe0e","timestamp":"2026-04-05T22:43:38.006Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/david/Go/src/github.com/cornjacket/ai-builder/establish-regression-recordings/sandbox/regressions/doc-user-service/output/internal/userservice/store/store.go","content":"// Package store provides a thread-safe in-memory store for User records.\n//\n// Purpose: CRUD operations on User records backed by a map guarded by sync.RWMutex,\n// with UUID generation for new record IDs.\n//\n// Tags: implementation, store\npackage store\n\nimport (\n\t\"sync\"\n\n\t\"github.com/google/uuid\"\n)\n\n// User represents a user record.\ntype User struct {\n\tID    string\n\tName  string\n\tEmail string\n}\n\n// Store is a thread-safe in-memory store for User records.\ntype Store struct {\n\tmu   sync.RWMutex\n\tdata map[string]User\n}\n\n// New returns an initialised *Store ready for use.\nfunc New() *Store {\n\treturn &Store{data: make(map[string]User)}\n}\n\n// Create ignores user.ID, assigns a fresh UUID, stores the record, and returns\n// the populated User.\nfunc (s *Store) Create(user User) User {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tuser.ID = uuid.NewString()\n\ts.data[user.ID] = user\n\treturn user\n}\n\n// Get returns the User for id and true, or an empty User and false if not found.\nfunc (s *Store) Get(id string) (User, bool) {\n\ts.mu.RLock()\n\tdefer s.mu.RUnlock()\n\n\tu, ok := s.data[id]\n\treturn u, ok\n}\n\n// Update replaces the stored record for id with user (preserving the original\n// ID) and returns the updated User and true. Returns (User{}, false) if id is\n// not found.\nfunc (s *Store) Update(id string, user User) (User, bool) {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif _, ok := s.data[id]; !ok {\n\t\treturn User{}, false\n\t}\n\tuser.ID = id\n\ts.data[id] = user\n\treturn user, true\n}\n\n// Delete removes the record for id and returns true, or false if not found.\nfunc (s *Store) Delete(id string) bool {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif _, ok := s.data[id]; !ok {\n\t\treturn false\n\t}\n\tdelete(s.data, id)\n\treturn true\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
