{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wso5eXjHfkfLPax5jM8XGm","type":"tool_result","content":"1\tpackage authz\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"net/http\"\n6\t\t\"sync\"\n7\t\n8\t\t\"github.com/google/uuid\"\n9\t)\n10\t\n11\ttype Role struct {\n12\t\tID          string   `json:\"id\"`\n13\t\tName        string   `json:\"name\"`\n14\t\tPermissions []string `json:\"permissions\"`\n15\t}\n16\t\n17\ttype UserRoleAssignment struct {\n18\t\tUserID string\n19\t\tRoleID string\n20\t}\n21\t\n22\ttype store struct {\n23\t\tmu          sync.RWMutex\n24\t\troles       map[string]Role\n25\t\tassignments []UserRoleAssignment\n26\t}\n27\t\n28\tfunc newStore() *store {\n29\t\treturn &store{\n30\t\t\troles:       make(map[string]Role),\n31\t\t\tassignments: []UserRoleAssignment{},\n32\t\t}\n33\t}\n34\t\n35\tfunc (s *store) addRole(name string, permissions []string) Role {\n36\t\tif permissions == nil {\n37\t\t\tpermissions = []string{}\n38\t\t}\n39\t\tr := Role{\n40\t\t\tID:          uuid.New().String(),\n41\t\t\tName:        name,\n42\t\t\tPermissions: permissions,\n43\t\t}\n44\t\ts.mu.Lock()\n45\t\ts.roles[r.ID] = r\n46\t\ts.mu.Unlock()\n47\t\treturn r\n48\t}\n49\t\n50\tfunc (s *store) listRoles() []Role {\n51\t\ts.mu.RLock()\n52\t\tdefer s.mu.RUnlock()\n53\t\tout := make([]Role, 0, len(s.roles))\n54\t\tfor _, r := range s.roles {\n55\t\t\tout = append(out, r)\n56\t\t}\n57\t\treturn out\n58\t}\n59\t\n60\tfunc (s *store) getRole(id string) (Role, bool) {\n61\t\ts.mu.RLock()\n62\t\tdefer s.mu.RUnlock()\n63\t\tr, ok := s.roles[id]\n64\t\treturn r, ok\n65\t}\n66\t\n67\t// assignRole returns false if roleID is unknown.\n68\tfunc (s *store) assignRole(userID, roleID string) bool {\n69\t\ts.mu.Lock()\n70\t\tdefer s.mu.Unlock()\n71\t\tif _, ok := s.roles[roleID]; !ok {\n72\t\t\treturn false\n73\t\t}\n74\t\ts.assignments = append(s.assignments, UserRoleAssignment{UserID: userID, RoleID: roleID})\n75\t\treturn true\n76\t}\n77\t\n78\tfunc (s *store) rolesForUser(userID string) []Role {\n79\t\ts.mu.RLock()\n80\t\tdefer s.mu.RUnlock()\n81\t\tout := []Role{}\n82\t\tfor _, a := range s.assignments {\n83\t\t\tif a.UserID == userID {\n84\t\t\t\tif r, ok := s.roles[a.RoleID]; ok {\n85\t\t\t\t\tout = append(out, r)\n86\t\t\t\t}\n87\t\t\t}\n88\t\t}\n89\t\treturn out\n90\t}\n91\t\n92\tfunc (s *store) hasPermission(userID, permission string) bool {\n93\t\ts.mu.RLock()\n94\t\tdefer s.mu.RUnlock()\n95\t\tfor _, a := range s.assignments {\n96\t\t\tif a.UserID != userID {\n97\t\t\t\tcontinue\n98\t\t\t}\n99\t\t\tr, ok := s.roles[a.RoleID]\n100\t\t\tif !ok {\n101\t\t\t\tcontinue\n102\t\t\t}\n103\t\t\tfor _, p := range r.Permissions {\n104\t\t\t\tif p == permission {\n105\t\t\t\t\treturn true\n106\t\t\t\t}\n107\t\t\t}\n108\t\t}\n109\t\treturn false\n110\t}\n111\t\n112\ttype Handler struct{ s *store }\n113\t\n114\tfunc New() *Handler {\n115\t\treturn &Handler{s: newStore()}\n116\t}\n117\t\n118\tfunc (h *Handler) RegisterRoutes(mux *http.ServeMux) {\n119\t\tmux.HandleFunc(\"POST /roles\", h.createRole)\n120\t\tmux.HandleFunc(\"GET /roles\", h.listRoles)\n121\t\tmux.HandleFunc(\"POST /users/{id}/roles\", h.assignRole)\n122\t\tmux.HandleFunc(\"GET /users/{id}/roles\", h.userRoles)\n123\t\tmux.HandleFunc(\"POST /authz/check\", h.checkPermission)\n124\t}\n125\t\n126\tfunc (h *Handler) createRole(w http.ResponseWriter, r *http.Request) {\n127\t\tvar req struct {\n128\t\t\tName        string   `json:\"name\"`\n129\t\t\tPermissions []string `json:\"permissions\"`\n130\t\t}\n131\t\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n132\t\t\thttp.Error(w, \"bad request\", http.StatusBadRequest)\n133\t\t\treturn\n134\t\t}\n135\t\trole := h.s.addRole(req.Name, req.Permissions)\n136\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n137\t\tw.WriteHeader(http.StatusCreated)\n138\t\tjson.NewEncoder(w).Encode(role)\n139\t}\n140\t\n141\tfunc (h *Handler) listRoles(w http.ResponseWriter, r *http.Request) {\n142\t\troles := h.s.listRoles()\n143\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n144\t\tjson.NewEncoder(w).Encode(roles)\n145\t}\n146\t\n147\tfunc (h *Handler) assignRole(w http.ResponseWriter, r *http.Request) {\n148\t\tuserID := r.PathValue(\"id\")\n149\t\tvar req struct {\n150\t\t\tRoleID string `json:\"roleId\"`\n151\t\t}\n152\t\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n153\t\t\thttp.Error(w, \"bad request\", http.StatusBadRequest)\n154\t\t\treturn\n155\t\t}\n156\t\tif !h.s.assignRole(userID, req.RoleID) {\n157\t\t\thttp.Error(w, \"role not found\", http.StatusNotFound)\n158\t\t\treturn\n159\t\t}\n160\t\tw.WriteHeader(http.StatusCreated)\n161\t}\n162\t\n163\tfunc (h *Handler) userRoles(w http.ResponseWriter, r *http.Request) {\n164\t\tuserID := r.PathValue(\"id\")\n165\t\troles := h.s.rolesForUser(userID)\n166\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n167\t\tjson.NewEncoder(w).Encode(roles)\n168\t}\n169\t\n170\tfunc (h *Handler) checkPermission(w http.ResponseWriter, r *http.Request) {\n171\t\tvar req struct {\n172\t\t\tUserID     string `json:\"userId\"`\n173\t\t\tPermission string `json:\"permission\"`\n174\t\t}\n175\t\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n176\t\t\thttp.Error(w, \"bad request\", http.StatusBadRequest)\n177\t\t\treturn\n178\t\t}\n179\t\tallowed := h.s.hasPermission(req.UserID, req.Permission)\n180\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n181\t\tjson.NewEncoder(w).Encode(map[string]bool{\"allowed\": allowed})\n182\t}\n183\t"}]},"parent_tool_use_id":null,"session_id":"adf9992c-b235-4f6c-b994-85744847c98d","uuid":"24d59dfd-6e74-4748-96fa-ac5f8a8c3db5","timestamp":"2026-04-05T22:28:50.155Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/david/Go/src/github.com/cornjacket/ai-builder/establish-regression-recordings/sandbox/regressions/doc-platform-monolith/output/internal/iam/authz/authz.go","content":"package authz\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"sync\"\n\n\t\"github.com/google/uuid\"\n)\n\ntype Role struct {\n\tID          string   `json:\"id\"`\n\tName        string   `json:\"name\"`\n\tPermissions []string `json:\"permissions\"`\n}\n\ntype UserRoleAssignment struct {\n\tUserID string\n\tRoleID string\n}\n\ntype store struct {\n\tmu          sync.RWMutex\n\troles       map[string]Role\n\tassignments []UserRoleAssignment\n}\n\nfunc newStore() *store {\n\treturn &store{\n\t\troles:       make(map[string]Role),\n\t\tassignments: []UserRoleAssignment{},\n\t}\n}\n\nfunc (s *store) addRole(name string, permissions []string) Role {\n\tif permissions == nil {\n\t\tpermissions = []string{}\n\t}\n\tr := Role{\n\t\tID:          uuid.New().String(),\n\t\tName:        name,\n\t\tPermissions: permissions,\n\t}\n\ts.mu.Lock()\n\ts.roles[r.ID] = r\n\ts.mu.Unlock()\n\treturn r\n}\n\nfunc (s *store) listRoles() []Role {\n\ts.mu.RLock()\n\tdefer s.mu.RUnlock()\n\tout := make([]Role, 0, len(s.roles))\n\tfor _, r := range s.roles {\n\t\tout = append(out, r)\n\t}\n\treturn out\n}\n\nfunc (s *store) getRole(id string) (Role, bool) {\n\ts.mu.RLock()\n\tdefer s.mu.RUnlock()\n\tr, ok := s.roles[id]\n\treturn r, ok\n}\n\n// assignRole returns false if roleID is unknown.\nfunc (s *store) assignRole(userID, roleID string) bool {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\tif _, ok := s.roles[roleID]; !ok {\n\t\treturn false\n\t}\n\ts.assignments = append(s.assignments, UserRoleAssignment{UserID: userID, RoleID: roleID})\n\treturn true\n}\n\nfunc (s *store) rolesForUser(userID string) []Role {\n\ts.mu.RLock()\n\tdefer s.mu.RUnlock()\n\tout := []Role{}\n\tfor _, a := range s.assignments {\n\t\tif a.UserID == userID {\n\t\t\tif r, ok := s.roles[a.RoleID]; ok {\n\t\t\t\tout = append(out, r)\n\t\t\t}\n\t\t}\n\t}\n\treturn out\n}\n\nfunc (s *store) hasPermission(userID, permission string) bool {\n\ts.mu.RLock()\n\tdefer s.mu.RUnlock()\n\tfor _, a := range s.assignments {\n\t\tif a.UserID != userID {\n\t\t\tcontinue\n\t\t}\n\t\tr, ok := s.roles[a.RoleID]\n\t\tif !ok {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, p := range r.Permissions {\n\t\t\tif p == permission {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\ntype Handler struct{ s *store }\n\nfunc New() *Handler {\n\treturn &Handler{s: newStore()}\n}\n\nfunc (h *Handler) RegisterRoutes(mux *http.ServeMux) {\n\tmux.HandleFunc(\"POST /roles\", h.createRole)\n\tmux.HandleFunc(\"GET /roles\", h.listRoles)\n\tmux.HandleFunc(\"POST /users/{id}/roles\", h.assignRole)\n\tmux.HandleFunc(\"GET /users/{id}/roles\", h.userRoles)\n\tmux.HandleFunc(\"POST /authz/check\", h.checkPermission)\n}\n\nfunc (h *Handler) createRole(w http.ResponseWriter, r *http.Request) {\n\tvar req struct {\n\t\tName        string   `json:\"name\"`\n\t\tPermissions []string `json:\"permissions\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\thttp.Error(w, \"bad request\", http.StatusBadRequest)\n\t\treturn\n\t}\n\trole := h.s.addRole(req.Name, req.Permissions)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusCreated)\n\tjson.NewEncoder(w).Encode(role)\n}\n\nfunc (h *Handler) listRoles(w http.ResponseWriter, r *http.Request) {\n\troles := h.s.listRoles()\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(roles)\n}\n\nfunc (h *Handler) assignRole(w http.ResponseWriter, r *http.Request) {\n\tuserID := r.PathValue(\"id\")\n\tvar req struct {\n\t\tRoleID string `json:\"roleId\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\thttp.Error(w, \"bad request\", http.StatusBadRequest)\n\t\treturn\n\t}\n\tif !h.s.assignRole(userID, req.RoleID) {\n\t\thttp.Error(w, \"role not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.WriteHeader(http.StatusCreated)\n}\n\nfunc (h *Handler) userRoles(w http.ResponseWriter, r *http.Request) {\n\tuserID := r.PathValue(\"id\")\n\troles := h.s.rolesForUser(userID)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(roles)\n}\n\nfunc (h *Handler) checkPermission(w http.ResponseWriter, r *http.Request) {\n\tvar req struct {\n\t\tUserID     string `json:\"userId\"`\n\t\tPermission string `json:\"permission\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\thttp.Error(w, \"bad request\", http.StatusBadRequest)\n\t\treturn\n\t}\n\tallowed := h.s.hasPermission(req.UserID, req.Permission)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]bool{\"allowed\": allowed})\n}\n","numLines":183,"startLine":1,"totalLines":183}}}
