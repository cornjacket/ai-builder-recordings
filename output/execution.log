— check permission; body: `{\"userId\": \"<string>\", \"permission\": \"<string>\"}` → 200 with `{\"allowed\": <bool>}`\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6524,"cache_read_input_tokens":11226,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6524},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"17aaf289-d594-4d9b-9bc7-386dc5fa6185","uuid":"fc1b9f5a-4873-4b82-a07a-9d813edccb41"}
